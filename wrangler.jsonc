{
	"compatibility_date": "2026-03-10",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"name": "facets-landing",
	"assets": {
		"binding": "ASSETS",
		"directory": "dist"
	},
	"observability": {
		"enabled": true
	},
	"$schema": "node_modules/wrangler/config-schema.json"
}