---
import logo from "@/assets/logo.png";
import GlobeIcon from "../assets/icons/glove.svg";

const navLinks = [
  { href: "#features", label: "Funciones" },
  { href: "#why-facets", label: "Ventajas" },
];
---
<header id="main-header" class="fixed top-0 left-0 right-0 z-50">
  <div id="header-shell" class="relative mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-5 sm:px-6 lg:h-20 lg:px-8">
    <a href="/" class="relative z-10 block flex-shrink-0">
      <img src={logo.src} alt="Facets" width={logo.width} height={logo.height} loading="eager" decoding="async" class="block h-7 w-auto md:h-8" />
    </a>

    <nav class="relative z-10 hidden items-center gap-6 md:flex lg:gap-8">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-link text-sm text-white/70 transition-colors duration-300 hover:text-white">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="relative z-10 inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-2 text-sm font-medium text-white/90 backdrop-blur-sm">
      <GlobeIcon class="h-4 w-4 shrink-0" fill="currentColor" />
      <span>ES</span>
    </div>
  </div>
</header>
