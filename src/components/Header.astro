---
import logo from "@/assets/logo.png";
import SignInIcon from "../assets/icons/sign-in.svg";
import UserCircleIcon from "../assets/icons/user-circle.svg";
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="header-bg absolute inset-0 bg-bg/80 backdrop-blur-md border-b border-white/5"></div>
  <div class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0 relative z-10 block">
      <img src={logo.src} alt="Facetas" width={logo.width} height={logo.height} loading="eager" decoding="async" class="block h-7 md:h-8 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#features" class="nav-link text-sm text-white/70 hover:text-white transition-colors duration-300">Funciones</a>
      <a href="#pricing" class="nav-link text-sm text-white/70 hover:text-white transition-colors duration-300">Precios</a>
      <a href="#about" class="nav-link text-sm text-white/70 hover:text-white transition-colors duration-300">Nosotros</a>
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center gap-5">
      <a href="#signin" class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors duration-300">
        <SignInIcon class="h-4 w-4 shrink-0" fill="currentColor" />
        Iniciar sesión
      </a>
      <a href="#signup" class="group flex items-center gap-2 text-sm px-5 py-2.5 rounded-full border border-white/15 text-white/90 hover:border-primary hover:text-primary hover:shadow-[0_0_20px_rgba(212,239,92,0.15)] transition-all duration-300">
        <UserCircleIcon class="h-[15px] w-[15px] shrink-0" fill="currentColor" />
        Crear cuenta
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button id="menu-toggle" class="md:hidden relative z-10 w-10 h-10 flex items-center justify-center" aria-label="Abrir menú">
      <div class="relative w-6 h-5">
        <span id="bar1" class="absolute left-0 top-0 w-full h-[2px] bg-white rounded-full"></span>
        <span id="bar2" class="absolute left-0 top-1/2 -translate-y-1/2 w-full h-[2px] bg-white rounded-full"></span>
        <span id="bar3" class="absolute left-0 bottom-0 w-full h-[2px] bg-white rounded-full"></span>
      </div>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="md:hidden fixed inset-0 top-16 pointer-events-none z-40">
    <div id="menu-backdrop" class="absolute inset-0 bg-bg/98 backdrop-blur-xl opacity-0"></div>
    <div class="relative h-full flex flex-col justify-between px-6 pt-8 pb-10">
      <nav class="flex flex-col gap-1">
        <a href="#features" class="mobile-link opacity-0 text-2xl font-display font-medium text-white/90 hover:text-primary py-3 transition-colors duration-300">Funciones</a>
        <a href="#pricing" class="mobile-link opacity-0 text-2xl font-display font-medium text-white/90 hover:text-primary py-3 transition-colors duration-300">Precios</a>
        <a href="#about" class="mobile-link opacity-0 text-2xl font-display font-medium text-white/90 hover:text-primary py-3 transition-colors duration-300">Nosotros</a>
      </nav>
      <div class="flex flex-col gap-3 mobile-cta opacity-0">
        <a href="#signin" class="flex items-center justify-center gap-2 text-base text-white/80 hover:text-white py-3 border border-white/10 rounded-2xl transition-colors duration-300">
          <SignInIcon class="h-[18px] w-[18px] shrink-0" fill="currentColor" />
          Iniciar sesión
        </a>
        <a href="#signup" class="flex items-center justify-center gap-2 text-base font-medium bg-primary text-bg py-3.5 rounded-2xl hover:bg-primary/90 transition-colors duration-300">
          <UserCircleIcon class="h-[18px] w-[18px] shrink-0" fill="currentColor" />
          Crear cuenta
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  import { gsap } from "gsap";

  const toggle = document.getElementById("menu-toggle")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const backdrop = document.getElementById("menu-backdrop")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const mobileCta = document.querySelector(".mobile-cta")!;

  let isOpen = false;
  let menuTl: gsap.core.Timeline | null = null;

  function openMenu() {
    isOpen = true;
    mobileMenu.classList.remove("pointer-events-none");

    if (menuTl) menuTl.kill();
    menuTl = gsap.timeline({ defaults: { ease: "power3.inOut" } });

    menuTl
      .to(bar1, { top: "50%", y: "-50%", rotation: 45, duration: 0.4 })
      .to(bar2, { opacity: 0, scaleX: 0, duration: 0.2 }, 0)
      .to(bar3, { bottom: "50%", y: "50%", rotation: -45, duration: 0.4 }, 0)
      .to(backdrop, { opacity: 1, duration: 0.35 }, 0)
      .to(
        mobileLinks,
        { opacity: 1, y: 0, duration: 0.4, stagger: 0.07 },
        0.15
      )
      .to(mobileCta, { opacity: 1, y: 0, duration: 0.4 }, 0.35);
  }

  function closeMenu() {
    isOpen = false;

    if (menuTl) menuTl.kill();
    menuTl = gsap.timeline({
      defaults: { ease: "power3.inOut" },
      onComplete: () => {
        mobileMenu.classList.add("pointer-events-none");
      },
    });

    menuTl
      .to(mobileCta, { opacity: 0, y: 10, duration: 0.25 })
      .to(
        [...mobileLinks].reverse(),
        { opacity: 0, y: -15, duration: 0.25, stagger: 0.04 },
        0
      )
      .to(backdrop, { opacity: 0, duration: 0.3 }, 0.1)
      .to(bar1, { top: "0%", y: "0%", rotation: 0, duration: 0.4 }, 0.1)
      .to(bar2, { opacity: 1, scaleX: 1, duration: 0.3 }, 0.15)
      .to(
        bar3,
        { bottom: "0%", y: "0%", rotation: 0, duration: 0.4 },
        0.1
      );
  }

  gsap.set(mobileLinks, { opacity: 0, y: 20 });
  gsap.set(mobileCta, { opacity: 0, y: 20 });

  toggle.addEventListener("click", () => {
    if (isOpen) closeMenu();
    else openMenu();
  });

  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) closeMenu();
    });
  });
</script>
