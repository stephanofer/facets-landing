---
import AppleLogoIcon from "../assets/icons/apple-logo.svg";
import GooglePlayLogoIcon from "../assets/icons/google-play-logo.svg";
import ArrowCircleUpIcon from "../assets/icons/arrow-circle-up.svg";
import StarbucksIcon from "../assets/icons/starbucks.svg";
import AmazonIcon from "../assets/icons/amazon.svg";
import PlazaVeaIcon from "../assets/icons/plaza-vea.svg";
import CarrefourIcon from "../assets/icons/carrefour.svg";
---

<section id="hero" class="relative min-h-[100svh] md:min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 md:pt-0 pb-12 sm:pb-16 px-5">
  <!-- Layered Ambient Background Gradients -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] lg:w-[1000px] lg:h-[1000px] rounded-full" style="background: radial-gradient(circle, rgba(212,239,92,0.07) 0%, rgba(212,239,92,0.02) 40%, transparent 70%);"></div>
    <div class="absolute -top-[10%] -right-[10%] w-[500px] h-[500px] lg:w-[700px] lg:h-[700px] rounded-full" style="background: radial-gradient(circle, rgba(56,189,248,0.04) 0%, rgba(56,189,248,0.01) 40%, transparent 70%);"></div>
    <div class="absolute -bottom-[5%] -left-[10%] w-[500px] h-[500px] lg:w-[650px] lg:h-[650px] rounded-full" style="background: radial-gradient(circle, rgba(168,85,247,0.04) 0%, rgba(168,85,247,0.01) 40%, transparent 70%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 0%, rgba(30,30,30,0.6) 0%, transparent 60%);"></div>
  </div>

  <!-- Desktop Floating Transaction Cards (lg+) -->
  <!-- Top-left: Starbucks (USD) -->
  <div class="floating-card hidden lg:block absolute top-[20%] left-[6%] xl:left-[12%]">
    <div class="tx-card">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[13px] text-white/70">Starbucks</p>
        <StarbucksIcon class="h-7 w-7 shrink-0" />
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <ArrowCircleUpIcon class="h-[18px] w-[18px] shrink-0" fill="#a1a1aa" />
        <span class="text-lg font-semibold text-white">$8.50</span>
      </div>
      <p class="text-[11px] text-white/40">Hoy, 9:42 AM</p>
    </div>
  </div>

  <!-- Top-right: Amazon (EUR) -->
  <div class="floating-card hidden lg:block absolute top-[16%] right-[6%] xl:right-[10%]">
    <div class="tx-card">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[13px] text-white/70">Amazon</p>
        <AmazonIcon class="h-7 w-7 shrink-0" />
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <ArrowCircleUpIcon class="h-[18px] w-[18px] shrink-0" fill="#a1a1aa" />
        <span class="text-lg font-semibold text-white">€52.99</span>
      </div>
      <p class="text-[11px] text-white/40">Ayer</p>
    </div>
  </div>

  <!-- Bottom-left: Plaza Vea (PEN) -->
  <div class="floating-card hidden lg:block absolute bottom-[20%] left-[4%] xl:left-[8%]">
    <div class="tx-card">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[13px] text-white/70">Plaza Vea</p>
        <PlazaVeaIcon class="h-7 w-7 shrink-0" />
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <ArrowCircleUpIcon class="h-[18px] w-[18px] shrink-0" fill="#a1a1aa" />
        <span class="text-lg font-semibold text-white">S/ 134.90</span>
      </div>
      <p class="text-[11px] text-white/40">Lunes</p>
    </div>
  </div>

  <!-- Bottom-right: Carrefour (ARS) -->
  <div class="floating-card hidden lg:block absolute bottom-[16%] right-[4%] xl:right-[8%]">
    <div class="tx-card">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[13px] text-white/70">Carrefour</p>
        <CarrefourIcon class="h-7 w-7 shrink-0" />
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <ArrowCircleUpIcon class="h-[18px] w-[18px] shrink-0" fill="#a1a1aa" />
        <span class="text-lg font-semibold text-white">$12,450</span>
      </div>
      <p class="text-[11px] text-white/40">Hoy, 5:31 PM</p>
    </div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center flex flex-col items-center">
    <h1 id="hero-title" class="font-display font-semibold text-[2.75rem] leading-[1.08] sm:text-6xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] tracking-tight text-white mb-6 sm:mb-8 md:mb-10">
      Gestiona Facil<br />tu dinero
    </h1> 
    <p id="hero-subtitle" class="text-muted text-sm sm:text-base mb-5 sm:mb-6">Descarga la app</p>

    <div id="hero-buttons" class="flex flex-col sm:flex-row items-stretch sm:items-center w-full max-w-sm sm:max-w-none sm:w-auto gap-3 sm:gap-4">
      <a href="#" data-open-qr-modal class="store-btn flex min-h-14 w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-4 py-2.5 text-sm font-medium text-bg transition-[background-color,box-shadow,transform] duration-300 hover:bg-primary/90 hover:shadow-[0_0_25px_rgba(212,239,92,0.2)] sm:min-h-[60px] sm:min-w-[190px] sm:w-auto sm:gap-3 sm:px-6 sm:py-3">
        <AppleLogoIcon class="h-5 w-5 shrink-0 sm:h-[22px] sm:w-[22px]" fill="currentColor" />
        <div class="flex min-w-0 flex-col items-start text-left leading-none">
          <span class="whitespace-nowrap text-[9px] leading-none opacity-80 sm:text-[10px]">Descargar en</span>
          <span class="whitespace-nowrap text-xs font-semibold leading-[1.1] sm:text-sm">App Store</span>
        </div>
      </a>
      <a href="#" data-open-qr-modal class="store-btn flex min-h-14 w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-4 py-2.5 text-sm font-medium text-bg transition-[background-color,box-shadow,transform] duration-300 hover:bg-primary/90 hover:shadow-[0_0_25px_rgba(212,239,92,0.2)] sm:min-h-[60px] sm:min-w-[190px] sm:w-auto sm:gap-3 sm:px-6 sm:py-3">
        <GooglePlayLogoIcon class="h-5 w-[18px] shrink-0 sm:h-[22px] sm:w-5" fill="currentColor" />
        <div class="flex min-w-0 flex-col items-start text-left leading-none">
          <span class="whitespace-nowrap text-[9px] leading-none opacity-80 sm:text-[10px]">Consíguela en</span>
          <span class="whitespace-nowrap text-xs font-semibold leading-[1.1] sm:text-sm">Google Play</span>
        </div>
      </a>
    </div>
  </div>

  <!-- Mobile Transaction Cards (below lg) -->
  <div class="lg:hidden relative z-10 mt-8 sm:mt-12 flex items-center gap-3">
    <div class="mobile-card tx-card">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[13px] text-white/70">Plaza Vea</p>
        <PlazaVeaIcon class="h-7 w-7 shrink-0" />
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <ArrowCircleUpIcon class="h-[18px] w-[18px] shrink-0" fill="#a1a1aa" />
        <span class="text-lg font-semibold text-white">S/ 134.90</span>
      </div>
      <p class="text-[11px] text-white/40">Lunes</p>
    </div>
    <div class="mobile-card tx-card">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[13px] text-white/70">Starbucks</p>
        <StarbucksIcon class="h-7 w-7 shrink-0" />
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <ArrowCircleUpIcon class="h-[18px] w-[18px] shrink-0" fill="#a1a1aa" />
        <span class="text-lg font-semibold text-white">$8.50</span>
      </div>
      <p class="text-[11px] text-white/40">Hoy</p>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  .floating-card { will-change: transform; }
  .floating-card:nth-child(1) { animation: float 3.4s ease-in-out 1s infinite; }
  .floating-card:nth-child(2) { animation: float 4.0s ease-in-out 1.5s infinite; }
  .floating-card:nth-child(3) { animation: float 3.8s ease-in-out 2s infinite; }
  .floating-card:nth-child(4) { animation: float 4.4s ease-in-out 2.5s infinite; }
</style>
