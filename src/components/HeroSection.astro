---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 md:pt-0 pb-12 sm:pb-16 px-5">
  <!-- Layered Ambient Background Gradients -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] lg:w-[1000px] lg:h-[1000px] rounded-full" style="background: radial-gradient(circle, rgba(212,239,92,0.07) 0%, rgba(212,239,92,0.02) 40%, transparent 70%);"></div>
    <div class="absolute -top-[10%] -right-[10%] w-[500px] h-[500px] lg:w-[700px] lg:h-[700px] rounded-full" style="background: radial-gradient(circle, rgba(56,189,248,0.04) 0%, rgba(56,189,248,0.01) 40%, transparent 70%);"></div>
    <div class="absolute -bottom-[5%] -left-[10%] w-[500px] h-[500px] lg:w-[650px] lg:h-[650px] rounded-full" style="background: radial-gradient(circle, rgba(168,85,247,0.04) 0%, rgba(168,85,247,0.01) 40%, transparent 70%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 0%, rgba(30,30,30,0.6) 0%, transparent 60%);"></div>
  </div>

  <!-- Desktop Floating Transaction Cards (lg+) -->
  <div class="floating-card hidden lg:block absolute top-[20%] left-[6%] xl:left-[12%]">
    <div class="bg-surface/80 backdrop-blur-sm border border-white/[0.08] rounded-2xl p-4 w-[195px] shadow-2xl shadow-black/50">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-primary/60 to-primary/20 flex items-center justify-center text-xs font-semibold text-bg shrink-0">RW</div>
        <div class="min-w-0">
          <p class="text-[11px] text-muted">Sent to</p>
          <p class="text-sm font-medium text-white truncate">Robert Wilson</p>
        </div>
      </div>
      <div class="flex items-center gap-1.5 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4ef5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        <span class="text-base font-semibold text-white">850<span class="text-muted">.00 EUR</span></span>
      </div>
      <p class="text-[11px] text-muted">10:45 AM</p>
    </div>
  </div>

  <div class="floating-card hidden lg:block absolute top-[16%] right-[6%] xl:right-[10%]">
    <div class="bg-surface-light/80 backdrop-blur-sm border border-white/[0.08] rounded-2xl p-4 w-[185px] shadow-2xl shadow-black/50">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-emerald-500/50 to-emerald-700/30 flex items-center justify-center text-xs font-semibold text-white shrink-0">S</div>
        <div class="min-w-0">
          <p class="text-[11px] text-muted">Paid to</p>
          <p class="text-sm font-medium text-white truncate">Starbucks</p>
        </div>
      </div>
      <div class="flex items-center gap-1.5 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4ef5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        <span class="text-base font-semibold text-white">50<span class="text-muted">.00 EUR</span></span>
      </div>
      <p class="text-[11px] text-muted">10:45 AM</p>
    </div>
  </div>

  <div class="floating-card hidden lg:block absolute bottom-[20%] left-[4%] xl:left-[8%]">
    <div class="bg-surface/80 backdrop-blur-sm border border-white/[0.08] rounded-2xl p-4 w-[190px] shadow-2xl shadow-black/50">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-amber-500/50 to-amber-700/30 flex items-center justify-center text-xs font-semibold text-white shrink-0">R</div>
        <div class="min-w-0">
          <p class="text-[11px] text-muted">Sent to</p>
          <p class="text-sm font-medium text-white truncate">Rüdiger</p>
        </div>
      </div>
      <div class="flex items-center gap-1.5 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4ef5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        <span class="text-base font-semibold text-white">2,000<span class="text-muted">.00 EUR</span></span>
      </div>
      <p class="text-[11px] text-muted">10:45 AM</p>
    </div>
  </div>

  <div class="floating-card hidden lg:block absolute bottom-[16%] right-[4%] xl:right-[8%]">
    <div class="bg-surface/80 backdrop-blur-sm border border-white/[0.08] rounded-2xl p-4 w-[200px] shadow-2xl shadow-black/50">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-500/50 to-violet-700/30 flex items-center justify-center text-xs font-semibold text-white shrink-0">CT</div>
        <div class="min-w-0">
          <p class="text-[11px] text-muted">Sent to</p>
          <p class="text-sm font-medium text-white truncate">Christopher T.</p>
        </div>
      </div>
      <div class="flex items-center gap-1.5 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4ef5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        <span class="text-base font-semibold text-white">1,590<span class="text-muted">.00 EUR</span></span>
      </div>
      <p class="text-[11px] text-muted">10:45 AM</p>
    </div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center flex flex-col items-center">
    <h1 id="hero-title" class="font-display font-semibold text-[2.75rem] leading-[1.08] sm:text-6xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] tracking-tight text-white mb-6 sm:mb-8 md:mb-10">
      Manage<br />your money
    </h1>

    <p id="hero-subtitle" class="text-muted text-sm sm:text-base mb-5 sm:mb-6">Download the app</p>

    <div id="hero-buttons" class="flex flex-col sm:flex-row items-stretch sm:items-center w-full sm:w-auto gap-3 sm:gap-4">
      <a href="#" class="store-btn flex items-center justify-center gap-2.5 sm:gap-3 bg-primary hover:bg-primary/90 text-bg font-medium text-sm px-4 sm:px-6 py-2.5 sm:py-3 rounded-xl transition-all duration-300 hover:shadow-[0_0_25px_rgba(212,239,92,0.2)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-[22px] sm:h-[22px]" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="flex flex-col">
          <span class="text-[9px] sm:text-[10px] leading-none opacity-80">Download on the</span>
          <span class="text-xs sm:text-sm font-semibold leading-tight">App Store</span>
        </div>
      </a>
      <a href="#" class="store-btn flex items-center justify-center gap-2.5 sm:gap-3 bg-primary hover:bg-primary/90 text-bg font-medium text-sm px-4 sm:px-6 py-2.5 sm:py-3 rounded-xl transition-all duration-300 hover:shadow-[0_0_25px_rgba(212,239,92,0.2)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-5 sm:w-5 sm:h-[22px]" viewBox="0 0 512 512" fill="currentColor">
          <path d="M48 59.49v393a4.33 4.33 0 007.37 3.07L260 256 55.37 56.42A4.33 4.33 0 0048 59.49zM345.8 174L89.22 32.64l-.16-.09c-4.42-2.4-8.62 3.58-5 7.06l201.13 192.32zM84.08 472.39c-3.64 3.48.56 9.46 5 7.06l.16-.09L345.8 338l-60.61-57.95zM449.38 231l-71.65-39.46L310.36 256l67.37 64.43 71.65-39.46c8.37-4.62 8.37-17.35 0-21.97z"/>
        </svg>
        <div class="flex flex-col">
          <span class="text-[9px] sm:text-[10px] leading-none opacity-80">GET IT ON</span>
          <span class="text-xs sm:text-sm font-semibold leading-tight">Google Play</span>
        </div>
      </a>
    </div>
  </div>

  <!-- Mobile Transaction Cards (below lg) -->
  <div class="lg:hidden relative z-10 mt-8 sm:mt-12 flex items-center gap-3">
    <div class="mobile-card bg-surface-light/70 border border-white/[0.06] rounded-2xl p-4 w-[150px]">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[11px] text-white/70">Amazon</p>
        <span class="text-sm font-bold text-amber-400">a</span>
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4ef5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 16"/><polyline points="8 12 12 8 16 12"/></svg>
        <span class="text-[15px] font-semibold text-white">$52.99</span>
      </div>
      <p class="text-[10px] text-white/40">Yesterday</p>
    </div>
    <div class="mobile-card bg-surface-light/70 border border-white/[0.06] rounded-2xl p-4 w-[150px]">
      <div class="flex items-center justify-between mb-3">
        <p class="text-[11px] text-white/70">Upwork</p>
        <span class="text-xs font-bold text-primary/80">Up</span>
      </div>
      <div class="flex items-center gap-1.5 mb-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d4ef5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 16 12 8"/><polyline points="16 12 12 16 8 12"/></svg>
        <span class="text-[15px] font-semibold text-white">$1,200.00</span>
      </div>
      <p class="text-[10px] text-white/40">12:26 PM</p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const title = document.getElementById("hero-title")!;
  const subtitle = document.getElementById("hero-subtitle")!;
  const buttons = document.getElementById("hero-buttons")!;
  const floatingCards = document.querySelectorAll(".floating-card");
  const mobileCards = document.querySelectorAll(".mobile-card");

  gsap.set([title, subtitle, buttons], { opacity: 0, y: 25 });
  gsap.set(floatingCards, { opacity: 0, scale: 0.95 });
  gsap.set(mobileCards, { opacity: 0, y: 12 });

  const tl = gsap.timeline({
    defaults: { ease: "power3.out" },
    delay: 0.1,
  });

  tl.to(title, { opacity: 1, y: 0, duration: 0.7 })
    .to(subtitle, { opacity: 1, y: 0, duration: 0.5 }, "-=0.35")
    .to(buttons, { opacity: 1, y: 0, duration: 0.5 }, "-=0.25")
    .to(
      floatingCards,
      {
        opacity: 1,
        scale: 1,
        duration: 0.6,
        stagger: 0.1,
      },
      "-=0.3"
    )
    .to(
      mobileCards,
      {
        opacity: 1,
        y: 0,
        duration: 0.4,
        stagger: 0.07,
      },
      "-=0.4"
    );

  floatingCards.forEach((card, i) => {
    gsap.to(card, {
      y: `-=${10 + Math.random() * 8}`,
      duration: 3 + Math.random() * 2,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: 1 + i * 0.5,
    });
  });
</script>
