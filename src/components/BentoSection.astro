---
---

<section id="why-facets" class="relative py-12 sm:py-20 lg:py-12 overflow-hidden" style="background-color: #ffffff;">
  <div class="max-w-[1400px] mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Section Title -->
    <div class="text-center mb-10 sm:mb-14 lg:mb-5">
      <h2 class="font-display font-semibold text-2xl sm:text-3xl md:text-4xl lg:text-[2.75rem] leading-[1.1] tracking-tight text-[#0f0f0f]">
        ¿Por qué usar Facets?
      </h2>
    </div>

    <!-- Bento Grid -->
    <div class="bento-grid">

      <!-- ═══ Card 1: All your accounts — FULL WIDTH TOP ═══ -->
      <div class="bento-top bento-card">
        <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-4">
          <!-- Text -->
          <div class="md:w-[52%] lg:w-[48%] md:pr-4">
            <h3 class="font-display font-semibold text-[1.55rem] sm:text-2xl lg:text-[1.85rem] leading-[1.15] text-[#0f0f0f] italic mb-3 lg:mb-4">
              All your accounts, all in<br class="hidden sm:block" /> one place
            </h3>
            <p class="text-[13px] sm:text-[14px] lg:text-[15px] text-[#777] leading-relaxed">
              Separate your personal and professional life for an easier transition between different roles and responsibilities. Consolidate all your financial accounts into one place in a hassle-free way.
            </p>
          </div>
          <!-- Credit Cards Illustration -->
          <div class="flex justify-center md:justify-end md:w-[48%] lg:w-[52%]">
            <div class="relative w-[240px] h-[170px] sm:w-[280px] sm:h-[190px] lg:w-[340px] lg:h-[220px]">
              <!-- Back card (darker, rotated left) -->
              <div class="absolute w-[155px] h-[98px] sm:w-[180px] sm:h-[113px] lg:w-[230px] lg:h-[145px] rounded-xl lg:rounded-2xl shadow-lg -rotate-[14deg] bottom-2 left-2 sm:bottom-1 sm:left-4 lg:bottom-0 lg:left-2 overflow-hidden"
                   style="background: linear-gradient(145deg, #1c2d4d 0%, #0e3f5e 100%);">
                <div class="absolute top-2.5 left-3 lg:top-4 lg:left-5">
                  <div class="w-7 h-5 lg:w-9 lg:h-6 rounded-[3px] bg-gradient-to-br from-amber-400/70 to-amber-600/50"></div>
                </div>
                <div class="absolute bottom-2.5 left-3 lg:bottom-3.5 lg:left-5 text-white/35 text-[7px] lg:text-[9px] font-mono tracking-[0.18em] uppercase">Debit Card</div>
                <div class="absolute top-0 right-0 w-20 h-20 lg:w-28 lg:h-28 bg-white/[0.04] rounded-full -translate-y-1/3 translate-x-1/4"></div>
              </div>
              <!-- Front card (blue-teal gradient, rotated right) -->
              <div class="absolute w-[155px] h-[98px] sm:w-[180px] sm:h-[113px] lg:w-[230px] lg:h-[145px] rounded-xl lg:rounded-2xl shadow-2xl rotate-[7deg] top-0 right-0 sm:top-0 sm:right-2 lg:top-0 lg:right-2 overflow-hidden"
                   style="background: linear-gradient(140deg, #0060b0 0%, #00a89c 55%, #00d0c0 100%);">
                <div class="absolute top-2.5 right-3 lg:top-4 lg:right-5 flex">
                  <div class="w-4 h-4 lg:w-5.5 lg:h-5.5 rounded-full bg-white/25"></div>
                  <div class="w-4 h-4 lg:w-5.5 lg:h-5.5 rounded-full bg-white/15 -ml-1.5 lg:-ml-2"></div>
                </div>
                <div class="absolute bottom-2.5 left-3 lg:bottom-3.5 lg:left-5 text-white/35 text-[7px] lg:text-[9px] font-mono tracking-[0.18em] uppercase">Debit Card</div>
                <div class="absolute -top-8 -right-8 w-24 h-24 lg:w-36 lg:h-36 bg-white/[0.08] rounded-full"></div>
                <div class="absolute top-1/2 right-1/4 w-14 h-14 lg:w-20 lg:h-20 bg-white/[0.04] rounded-full"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Card 2: Analytics Chart — LEFT MIDDLE ═══ -->
      <div class="bento-chart bento-card">
        <!-- Header -->
        <div class="flex items-center justify-between mb-4 lg:mb-5">
          <div class="flex items-baseline gap-1.5">
            <span class="font-display font-semibold text-[1.5rem] lg:text-[1.7rem] text-[#0f0f0f] leading-none">45,000</span>
            <span class="text-[11px] lg:text-xs text-[#aaa]">collected</span>
          </div>
          <div class="flex items-center gap-1.5 px-2 py-1.5 rounded-lg border border-[#e2e2e2] text-[10px] lg:text-[11px] text-[#bbb] select-none">
            <span>DD / MM / YYYY</span>
            <svg class="w-3 h-3 lg:w-3.5 lg:h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
        </div>

        <!-- Chart Area -->
        <div class="relative pl-7 lg:pl-8 mb-2.5">
          <!-- Y-axis -->
          <div class="absolute left-0 top-0 bottom-5 flex flex-col justify-between text-[9px] lg:text-[10px] text-[#ccc] leading-none">
            <span>90k</span>
            <span>70k</span>
            <span>50k</span>
            <span>30k</span>
            <span>10k</span>
            <span>0</span>
          </div>

          <!-- Bars -->
          <div class="flex items-end justify-between h-[125px] lg:h-[148px] gap-1.5 lg:gap-2 border-b border-[#ebebeb]">
            <!-- Jan -->
            <div class="flex-1 flex items-end justify-center gap-[2px] lg:gap-[3px]">
              <div class="w-[10px] lg:w-[13px] rounded-t-[3px] bg-[#b0ddd0]" style="height: 85%"></div>
              <div class="w-[10px] lg:w-[13px] rounded-t-[3px] bg-[#c8dce8]" style="height: 38%"></div>
            </div>
            <!-- Feb -->
            <div class="flex-1 flex items-end justify-center gap-[2px] lg:gap-[3px]">
              <div class="w-[8px] lg:w-[10px] rounded-t-[3px] bg-[#e8a5a5]" style="height: 55%"></div>
              <div class="w-[8px] lg:w-[10px] rounded-t-[3px] bg-[#dda5c0]" style="height: 48%"></div>
              <div class="w-[8px] lg:w-[10px] rounded-t-[3px] bg-[#c99a6a]" style="height: 32%"></div>
            </div>
            <!-- Mar (with tooltip) -->
            <div class="flex-1 flex items-end justify-center gap-[2px] lg:gap-[3px] relative">
              <div class="chart-tooltip absolute -top-[52px] lg:-top-[56px] left-1/2 -translate-x-1/2 bg-[#2a2a2a] text-white rounded-lg px-2.5 py-1.5 whitespace-nowrap z-10 shadow-lg">
                <div class="text-[9px] lg:text-[10px] text-[#bbb] font-medium mb-0.5">House</div>
                <div class="text-[9px] lg:text-[10px]">This month: <span class="font-semibold">$11,000</span></div>
                <div class="text-[8px] lg:text-[9px] text-[#888]">Last month: $9,300</div>
                <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-full w-0 h-0 border-l-[5px] border-r-[5px] border-t-[5px] border-transparent border-t-[#2a2a2a]"></div>
              </div>
              <div class="w-[8px] lg:w-[10px] rounded-t-[3px] bg-[#b0ddd0]" style="height: 24%"></div>
              <div class="w-[8px] lg:w-[10px] rounded-t-[3px] bg-[#e8a5a5]" style="height: 40%"></div>
              <div class="w-[8px] lg:w-[10px] rounded-t-[3px] bg-[#c99a6a]" style="height: 30%"></div>
            </div>
            <!-- Apr -->
            <div class="flex-1 flex items-end justify-center gap-[2px] lg:gap-[3px]">
              <div class="w-[10px] lg:w-[13px] rounded-t-[3px] bg-[#7aba8c]" style="height: 18%"></div>
              <div class="w-[10px] lg:w-[13px] rounded-t-[3px] bg-[#c99a6a]" style="height: 24%"></div>
            </div>
            <!-- May -->
            <div class="flex-1 flex items-end justify-center gap-[2px] lg:gap-[3px]">
              <div class="w-[10px] lg:w-[13px] rounded-t-[3px] bg-[#c99a6a]" style="height: 28%"></div>
              <div class="w-[10px] lg:w-[13px] rounded-t-[3px] bg-[#d4a06a]" style="height: 16%"></div>
            </div>
          </div>

          <!-- X-axis -->
          <div class="flex justify-between text-[10px] lg:text-[11px] text-[#bbb] mt-1.5">
            <span class="flex-1 text-center">Jan</span>
            <span class="flex-1 text-center">Feb</span>
            <span class="flex-1 text-center">Mar</span>
            <span class="flex-1 text-center">Apr</span>
            <span class="flex-1 text-center">May</span>
          </div>
        </div>

        <!-- Legend -->
        <div class="flex flex-wrap gap-x-3 gap-y-1.5 text-[9px] lg:text-[10px] text-[#aaa] mt-3 lg:mt-4">
          <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-[#b0ddd0]"></span>Vacation</span>
          <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-[#e8a5a5]"></span>Education</span>
          <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-[#dda5c0]"></span>Flat in Downtown</span>
          <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-[#7aba8c]"></span>Car</span>
          <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-[#c99a6a]"></span>House</span>
        </div>
      </div>

      <!-- ═══ Card 3: Control your budget — RIGHT, SPANS 2 ROWS ═══ -->
      <div class="bento-budget bento-card flex flex-col">
        <h3 class="font-display font-semibold text-xl sm:text-2xl lg:text-[1.7rem] leading-[1.15] text-[#0f0f0f] mb-2 lg:mb-3">
          Control your budget
        </h3>
        <p class="text-[13px] lg:text-[14px] text-[#777] leading-relaxed mb-5 lg:mb-6">
          Controlling and knowing your budget can help you to avoid overspending and ensure you have enough money to cover your bills and expenses.
        </p>

        <!-- Phone Mockup -->
        <div class="flex-1 flex justify-center items-end overflow-hidden mt-auto -mb-6 sm:-mb-7 lg:-mb-8">
          <div class="phone-frame relative w-[200px] sm:w-[220px] lg:w-[250px]">
            <div class="bg-[#1a1a1a] rounded-[1.8rem] sm:rounded-[2rem] lg:rounded-[2.2rem] pt-2 px-2 pb-0 shadow-2xl border border-[#333]">
              <!-- Status bar -->
              <div class="relative flex items-center justify-between px-4 pt-1.5 pb-1 text-white">
                <span class="text-[10px] font-semibold">9:41</span>
                <div class="absolute left-1/2 -translate-x-1/2 w-[72px] h-[22px] bg-black rounded-full top-0.5"></div>
                <div class="flex items-center gap-[3px]">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="white"><path d="M2 22h3V10H2v12zm5 0h3V7H7v15zm5 0h3V4h-3v18zm5 0h3V7h-3v15zm5 0h3V10h-3v12z"/></svg>
                  <svg class="w-3.5 h-3" viewBox="0 0 24 24" fill="white"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
                  <svg class="w-4 h-3" viewBox="0 0 28 14" fill="none"><rect x="0.5" y="0.5" width="22" height="13" rx="2" stroke="white" stroke-opacity="0.5"/><rect x="2" y="2" width="14" height="10" rx="1" fill="white"/><rect x="24" y="4" width="3" height="6" rx="1" fill="white" fill-opacity="0.4"/></svg>
                </div>
              </div>

              <!-- Screen -->
              <div class="bg-[#1a1a1a] rounded-t-lg px-3 pt-2.5 pb-5">
                <div class="flex items-center justify-between mb-1.5">
                  <span class="text-white/60 text-[10px]">My capital</span>
                  <span class="text-[#7aba8c] text-[8px]">5m ago ↻</span>
                </div>
                <div class="mb-0.5">
                  <span class="text-white/40 text-[8px]">Net worth</span>
                </div>
                <div class="flex items-baseline gap-2 mb-2.5">
                  <span class="text-white font-semibold text-[15px] lg:text-[17px] leading-none">$1,43,899.96</span>
                  <span class="text-[#7aba8c] text-[9px]">↑ 10%</span>
                </div>

                <!-- Mini line chart -->
                <div class="h-5 mb-3 relative">
                  <svg viewBox="0 0 200 28" class="w-full h-full" preserveAspectRatio="none">
                    <defs>
                      <linearGradient id="bentoChartGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#4ade80" stop-opacity="0.2"/>
                        <stop offset="100%" stop-color="#4ade80" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path d="M0,24 Q25,22 50,18 T100,12 T150,7 T200,4" fill="none" stroke="#4ade80" stroke-width="1.5"/>
                    <path d="M0,24 Q25,22 50,18 T100,12 T150,7 T200,4 V28 H0 Z" fill="url(#bentoChartGrad)"/>
                  </svg>
                </div>

                <!-- Category cards 2×2 -->
                <div class="grid grid-cols-2 gap-1.5">
                  <div class="rounded-lg p-2" style="background: #f0ddd6;">
                    <span class="text-[7px] lg:text-[8px] block mb-1" style="color: #c47060;">Credit cards</span>
                    <div class="h-3.5 mb-1">
                      <svg viewBox="0 0 60 14" class="w-full h-full" preserveAspectRatio="none"><path d="M0,10 Q10,8 20,6 T40,8 T60,5" fill="none" stroke="#c47060" stroke-width="1" opacity="0.5"/></svg>
                    </div>
                    <div class="flex items-baseline justify-between">
                      <span class="text-[#1a1a1a] font-semibold text-[9px] lg:text-[10px]">$84,332</span>
                      <span class="text-[#7aba8c] text-[6px] lg:text-[7px]">↑ 5%</span>
                    </div>
                  </div>
                  <div class="rounded-lg p-2" style="background: #f2e0e0;">
                    <span class="text-[7px] lg:text-[8px] block mb-1" style="color: #c08080;">Cash</span>
                    <div class="h-3.5 mb-1">
                      <svg viewBox="0 0 60 14" class="w-full h-full" preserveAspectRatio="none"><path d="M0,12 Q15,10 30,6 T60,4" fill="none" stroke="#c08080" stroke-width="1" opacity="0.5"/></svg>
                    </div>
                    <div class="flex items-baseline justify-between">
                      <span class="text-[#1a1a1a] font-semibold text-[9px] lg:text-[10px]">$1,428</span>
                      <span class="text-[#7aba8c] text-[6px] lg:text-[7px]">↑ 16%</span>
                    </div>
                  </div>
                  <div class="rounded-lg p-2" style="background: #d8eee4;">
                    <span class="text-[7px] lg:text-[8px] block mb-1" style="color: #5a9a78;">Savings</span>
                    <div class="h-3.5 mb-1">
                      <svg viewBox="0 0 60 14" class="w-full h-full" preserveAspectRatio="none"><path d="M0,12 Q15,7 30,5 T60,2" fill="none" stroke="#5a9a78" stroke-width="1" opacity="0.5"/></svg>
                    </div>
                    <div class="flex items-baseline justify-between">
                      <span class="text-[#1a1a1a] font-semibold text-[9px] lg:text-[10px]">$7,332</span>
                      <span class="text-[#7aba8c] text-[6px] lg:text-[7px]">↑ 78%</span>
                    </div>
                  </div>
                  <div class="rounded-lg p-2" style="background: #eeead8;">
                    <span class="text-[7px] lg:text-[8px] block mb-1" style="color: #9a8a58;">Property</span>
                    <div class="h-3.5 mb-1">
                      <svg viewBox="0 0 60 14" class="w-full h-full" preserveAspectRatio="none"><path d="M0,8 Q15,10 30,6 T60,7" fill="none" stroke="#9a8a58" stroke-width="1" opacity="0.5"/></svg>
                    </div>
                    <span class="text-[#1a1a1a] font-semibold text-[9px] lg:text-[10px]">$939,000</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Card 4: Upcoming Bills — LEFT BOTTOM ═══ -->
      <div class="bento-bills bento-card">
        <div class="flex items-start justify-between mb-4 lg:mb-5">
          <div>
            <p class="text-[12px] lg:text-[13px] text-[#aaa] mb-0.5">Upcoming bills</p>
            <p class="font-display font-semibold text-[1.5rem] lg:text-[1.7rem] text-[#0f0f0f] leading-none">$1,560</p>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-7 h-7 lg:w-8 lg:h-8 rounded-lg border border-[#e0e0e0] flex items-center justify-center text-[#c0c0c0]">
              <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div class="w-7 h-7 lg:w-8 lg:h-8 rounded-lg border border-[#e0e0e0] flex items-center justify-center text-[#c0c0c0] text-base leading-none">+</div>
            <div class="px-2.5 py-1.5 rounded-lg border border-[#e0e0e0] text-[11px] lg:text-[12px] text-[#aaa] select-none">View all</div>
          </div>
        </div>

        <!-- Subscription Items -->
        <div class="grid grid-cols-3 gap-2 lg:gap-3">
          <!-- Figma -->
          <div class="bg-white rounded-xl p-2.5 lg:p-3 text-center">
            <div class="w-8 h-8 lg:w-9 lg:h-9 mx-auto mb-2 flex items-center justify-center">
              <svg viewBox="0 0 38 57" class="w-5 h-7 lg:w-6 lg:h-8">
                <path fill="#1abcfe" d="M19 28.5a9.5 9.5 0 1 1 19 0 9.5 9.5 0 0 1-19 0z"/>
                <path fill="#0acf83" d="M0 47.5A9.5 9.5 0 0 1 9.5 38H19v9.5a9.5 9.5 0 1 1-19 0z"/>
                <path fill="#ff7262" d="M19 0v19h9.5a9.5 9.5 0 1 0 0-19H19z"/>
                <path fill="#f24e1e" d="M0 9.5A9.5 9.5 0 0 0 9.5 19H19V0H9.5A9.5 9.5 0 0 0 0 9.5z"/>
                <path fill="#a259ff" d="M0 28.5A9.5 9.5 0 0 0 9.5 38H19V19H9.5A9.5 9.5 0 0 0 0 28.5z"/>
              </svg>
            </div>
            <p class="text-[11px] lg:text-xs font-medium text-[#0f0f0f] mb-1">Figma</p>
            <p class="font-display font-semibold text-[15px] lg:text-base text-[#0f0f0f] leading-none">$84<span class="text-[10px] lg:text-[11px] font-normal text-[#bbb]"> /mo</span></p>
            <p class="text-[9px] lg:text-[10px] text-[#c0c0c0] mt-1">Tomorrow</p>
          </div>
          <!-- Tinder Gold -->
          <div class="bg-white rounded-xl p-2.5 lg:p-3 text-center">
            <div class="w-8 h-8 lg:w-9 lg:h-9 mx-auto mb-2 flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-6 h-6 lg:w-7 lg:h-7">
                <defs><linearGradient id="tinderGrad" x1="0.5" y1="0" x2="0.5" y2="1"><stop offset="0%" stop-color="#fd5068"/><stop offset="100%" stop-color="#e6395a"/></linearGradient></defs>
                <path fill="url(#tinderGrad)" d="M12.003 2C8.913 6.236 5.5 8.5 5.5 13c0 3.59 2.91 6.5 6.5 6.5s6.5-2.91 6.5-6.5c0-4.5-3.413-6.764-6.497-11zm-.49 15.5c-1.933 0-3.5-1.567-3.5-3.5 0-1.102.548-2.4 1.4-3.5.6.9 1.517 1.618 2.6 2 .283.1.5.35.5.65 0 .35-.267.65-.6.75A1.752 1.752 0 0 0 10.5 15.5c0 .555.445 1 1 1 .557 0 1-.445 1-1z"/>
              </svg>
            </div>
            <p class="text-[11px] lg:text-xs font-medium text-[#0f0f0f] mb-1">Tinder Gold</p>
            <p class="font-display font-semibold text-[15px] lg:text-base text-[#0f0f0f] leading-none">$37<span class="text-[10px] lg:text-[11px] font-normal text-[#bbb]"> /mo</span></p>
            <p class="text-[9px] lg:text-[10px] text-[#c0c0c0] mt-1">18 Dec</p>
          </div>
          <!-- Internet -->
          <div class="bg-white rounded-xl p-2.5 lg:p-3 text-center">
            <div class="w-8 h-8 lg:w-9 lg:h-9 mx-auto mb-2 flex items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-6 h-6 lg:w-7 lg:h-7" fill="none" stroke="#333" stroke-width="1.8">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
                <line x1="12" y1="2" x2="12" y2="6"/>
                <line x1="12" y1="18" x2="12" y2="22"/>
                <line x1="2" y1="12" x2="6" y2="12"/>
                <line x1="18" y1="12" x2="22" y2="12"/>
              </svg>
            </div>
            <p class="text-[11px] lg:text-xs font-medium text-[#0f0f0f] mb-1">Internet</p>
            <p class="font-display font-semibold text-[15px] lg:text-base text-[#0f0f0f] leading-none">$120<span class="text-[10px] lg:text-[11px] font-normal text-[#bbb]"> /mo</span></p>
            <p class="text-[9px] lg:text-[10px] text-[#c0c0c0] mt-1">18 Dec</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

