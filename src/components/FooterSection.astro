---
import logo from "@/assets/logo.png";
import TiktokIcon from "@/assets/icons/tiktok.svg";
import InstagramIcon from "@/assets/icons/instagram.svg";
import EnvelopeIcon from "@/assets/icons/envelope.svg";
---

<footer class="relative bg-black">
  <!-- Subtle top border gradient -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Main Footer Row -->
    <div class="py-10 sm:py-12 lg:py-14 flex flex-col lg:flex-row lg:items-start lg:justify-between gap-10 lg:gap-8">

      <!-- Left: Logo + Copyright -->
      <div class="flex flex-col items-center lg:items-start gap-4 shrink-0">
        <a href="/" class="block">
          <img
            src={logo.src}
            alt="Facets"
            width={logo.width}
            height={logo.height}
            loading="lazy"
            decoding="async"
            class="h-7 w-auto"
          />
        </a>
        <p class="text-white/30 text-xs">
          &copy; {new Date().getFullYear()} Facets. Todos los derechos reservados.
        </p>
      </div>

      <!-- Center: Navigation Links -->
      <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <a href="#features" class="footer-link text-white/50 hover:text-white transition-colors duration-300">Funciones</a>
        <a href="#pricing" class="footer-link text-white/50 hover:text-white transition-colors duration-300">Precios</a>
        <a href="#about" class="footer-link text-white/50 hover:text-white transition-colors duration-300">Nosotros</a>
        <a href="/privacy" class="footer-link text-white/50 hover:text-white transition-colors duration-300">Privacidad</a>
        <a href="/terms" class="footer-link text-white/50 hover:text-white transition-colors duration-300">Términos</a>
      </nav>

      <!-- Right: Social Icons + Made with love -->
      <div class="flex flex-col items-center lg:items-end gap-5 shrink-0">
        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          <a
            href="https://tiktok.com/@facets"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok"
            class="social-icon group flex items-center justify-center w-10 h-10 rounded-full border border-white/10 bg-white/[0.03] hover:border-primary/40 hover:bg-primary/10 transition-all duration-300"
          >
            <TiktokIcon class="w-[18px] h-[18px] text-white/50 group-hover:text-primary transition-colors duration-300" fill="currentColor" />
          </a>
          <a
            href="https://instagram.com/facets"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="social-icon group flex items-center justify-center w-10 h-10 rounded-full border border-white/10 bg-white/[0.03] hover:border-primary/40 hover:bg-primary/10 transition-all duration-300"
          >
            <InstagramIcon class="w-[18px] h-[18px] text-white/50 group-hover:text-primary transition-colors duration-300" fill="currentColor" />
          </a>
          <a
            href="mailto:hello@facets.app"
            aria-label="Email"
            class="social-icon group flex items-center justify-center w-10 h-10 rounded-full border border-white/10 bg-white/[0.03] hover:border-primary/40 hover:bg-primary/10 transition-all duration-300"
          >
            <EnvelopeIcon class="w-[18px] h-[18px] text-white/50 group-hover:text-primary transition-colors duration-300" fill="currentColor" />
          </a>
        </div>

        <!-- Made with love -->
        <p class="flex items-center gap-1.5 text-xs text-white/30">
          Hecho con
          <span class="inline-block text-red-500 text-sm animate-pulse">&#10084;</span>
          para ti
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    position: relative;
  }

  .footer-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--color-primary);
    transition: width 0.3s ease;
  }

  .footer-link:hover::after {
    width: 100%;
  }

  .social-icon {
    will-change: transform;
  }

  .social-icon:hover {
    transform: translateY(-2px);
  }
</style>
