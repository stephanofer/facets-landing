---
const reviews = [
  {
    name: "Mariana López",
    comment:
      "Facets cambió por completo cómo manejo mis finanzas. Ahora tengo control total de mis gastos y metas de ahorro. La interfaz es increíblemente intuitiva.",
    avatar: "https://i.pravatar.cc/96?img=47",
    rating: 5,
  },
  {
    name: "Carlos Rivera",
    comment:
      "Llevaba años buscando una app que me dejara ver todas mis cuentas en un solo lugar. Facets lo hace perfecto, además el diseño es hermoso y muy fácil de usar.",
    avatar: "https://i.pravatar.cc/96?img=12",
    rating: 5,
  },
  {
    name: "Valentina Torres",
    comment:
      "Lo mejor es que puedo gestionar deudas y presupuestos sin complicarme. Es como tener un asesor financiero en el bolsillo. Totalmente recomendada.",
    avatar: "https://i.pravatar.cc/96?img=45",
    rating: 5,
  },
  {
    name: "Andrés Guzmán",
    comment:
      "Desde que uso Facets mis finanzas están en orden. La visibilidad que me da sobre mis gastos mensuales es algo que ninguna otra app me había ofrecido antes.",
    avatar: "https://i.pravatar.cc/96?img=68",
    rating: 5,
  },
];
---

<section class="relative py-12 overflow-hidden bg-black">
  <div class="max-w-[1400px] mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Section Title -->
    <div class="text-center mb-10 sm:mb-12">
      <h2
        class="font-display font-semibold text-2xl sm:text-3xl md:text-4xl lg:text-[2.75rem] leading-[1.1] tracking-tight text-white"
      >
        Reseñas de usuarios reales
      </h2>
    </div>

    <!-- Reviews Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
      {
        reviews.map((review) => (
          <div class="review-card">
            {/* Stars */}
            <div class="flex gap-[3px] mb-4">
              {Array.from({ length: review.rating }).map(() => (
                <svg
                  class="w-[18px] h-[18px] sm:w-5 sm:h-5"
                  viewBox="0 0 24 24"
                  fill="#10b981"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>

            {/* Comment */}
            <p class="text-[#1a1a1a] text-[14px] sm:text-[15px] leading-relaxed font-normal mb-6 flex-1">
              {review.comment}
            </p>

            {/* User Info */}
            <div class="flex items-center gap-3 mt-auto">
              <img
                src={review.avatar}
                alt={review.name}
                width="40"
                height="40"
                loading="lazy"
                decoding="async"
                class="w-10 h-10 rounded-full object-cover"
              />
              <span class="text-[#1a1a1a] text-[14px] font-medium">
                {review.name}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .review-card {
    background: #f7f7f7;
    border-radius: 1.25rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 1024px) {
    .review-card {
      border-radius: 1.375rem;
      padding: 1.625rem;
    }
  }
</style>
